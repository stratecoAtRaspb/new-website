{
  "name": "new-website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "dev": "node scripts/sync-from-hygraph.mjs --no-fail && vite dev",
    "sync:hygraph": "node scripts/sync-from-hygraph.mjs",
    "import:hygraph": "node scripts/import-to-hygraph.mjs",
    "repair:de": "node scripts/repair-de-localizations.mjs",
    "prebuild": "node scripts/sync-from-hygraph.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint ."
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@inlang/paraglide-js": "^2.12.0",
    "@sveltejs/adapter-netlify": "^6.0.3",
    "@sveltejs/kit": "^2.53.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/nesting": "^0.0.0-insiders.565cd3e",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.3.0",
    "autoprefixer": "^10.4.24",
    "daisyui": "^5.5.19",
    "eslint": "^10.0.1",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.53.3",
    "svelte-check": "^4.4.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "graphql": "^16.12.0",
    "graphql-request": "^7.4.0",
    "mapbox-gl": "^3.18.1",
    "swiper": "^12.1.2",
    "vanilla-cookieconsent": "^3.1.0"
  }
}
